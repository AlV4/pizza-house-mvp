{
    "name": "pizza-house/app",
    "description": "Pizza House — modular monolith demonstrating DDD, CQRS, and event-driven design",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*",
        "doctrine/dbal": "^4.2",
        "doctrine/doctrine-bundle": "^2.13",
        "doctrine/doctrine-migrations-bundle": "^3.4",
        "doctrine/orm": "^3.3",
        "symfony/console": "^7.1",
        "symfony/dotenv": "^7.1",
        "symfony/framework-bundle": "^7.1",
        "symfony/messenger": "^7.1",
        "symfony/doctrine-messenger": "^7.1",
        "symfony/runtime": "^7.1",
        "symfony/serializer": "^7.1",
        "symfony/uid": "^7.1",
        "symfony/yaml": "^7.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.3",
        "symfony/browser-kit": "^7.1",
        "symfony/phpunit-bridge": "^7.1"
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        },
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    }
}
